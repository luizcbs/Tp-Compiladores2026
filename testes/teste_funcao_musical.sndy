// Declaração da função 'soma' (C7 A7 soma) com parâmetros 'a' e 'b'
C7 A7 G G F#m C7 A A F#m C7 E E F#m C
    // C7 G7 resultado Bbm B C
    C7 G7 D D F#m Bbm B C
    
    // Em resultado a b B C
    Em D D F#m A A F#m E E F#m B C
    
    // F#7 resultado B C (Retorno)
    F#7 D D F#m B C
Bbm

// C7 G7 principal Bbm B C
C7 G7 A G F#m Bbm B C

// F#maj7 principal soma 10 20 B C
F#maj7 A G F#m G G F#m Emaj7 Emaj7 Abm Dmaj7 Dmaj7 Cmaj7 Abm B C
